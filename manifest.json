{
  "manifest_version": 3,
  "name": "Prompt Navigator",
  "version": "1.0.0",
  "description": "Navigate your AI chat prompts efficiently.",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/app/*"],
      "js": ["content/gemini.js"],
      "css": ["styles/gemini.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/claude.js"],
      "css": ["styles/claude.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/c/*"],
      "js": ["content/chatgpt.js"],
      "css": ["styles/chatgpt.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://copilot.microsoft.com/*"],
      "js": ["content/copilot.js"],
      "css": ["styles/copilot.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.perplexity.ai/search/*"],
      "js": ["content/perplexity.js"],
      "css": ["styles/perplexity.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.deepseek.com/a/chat/*"],
      "js": ["content/deepseek.js"],
      "css": ["styles/deepseek.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://poe.com/chat/*"],
      "js": ["content/poe.js"],
      "css": ["styles/poe.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.meta.ai/prompt/*"],
      "js": ["content/meta.js"],
      "css": ["styles/meta.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://grok.com/c/*"],
      "js": ["content/grok.js"],
      "css": ["styles/grok.css"],
      "run_at": "document_idle"
    }
  ]
}