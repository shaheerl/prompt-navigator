{
  "manifest_version": 3,
  "name": "Prompt Navigator",
  "version": "1.0.0",
  "description": "Navigate your AI chat prompts efficiently.",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/app/*"],
      "js": ["content/gemini.js"],
      "css": ["styles/navigator.css"],
      "run_at": "document_idle"
    }
  ]
}